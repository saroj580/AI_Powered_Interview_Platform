generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  CODING
  VOICE
  MIXED
}

enum InterviewStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  name           String
  email          String         @unique
  password       String
  image          String?
  role           Role           @default(CANDIDATE)
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  organizationId String?
  interviews     Interview[]    @relation("InterviewCreator")
  resumes        Resume[]
  sessions       Session[]
  evaluations    Evaluation[]
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  interviews  Interview[]
}

model Interview {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  title           String
  description     String?
  type            InterviewType @default(TECHNICAL)
  status          InterviewStatus @default(DRAFT)
  targetRole      String
  difficulty      Difficulty     @default(MEDIUM)
  questionCount   Int             @default(5)
  durationMinutes Int             @default(30)
  totalScore      Float?         
  createdBy       User?          @relation("InterviewCreator", fields: [createdById], references: [id])
  createdById     String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  organizationId  String?
  sessions        Session[]
}

model Resume {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  fileUrl    String
  parsedText String?
  summary    String?
}

model Session {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  interview      Interview      @relation(fields: [interviewId], references: [id])
  interviewId    String
  user           User           @relation(fields: [userId], references: [id])
  userId         String
  status         InterviewStatus @default(SCHEDULED)
  startedAt      DateTime?
  endedAt        DateTime?
  score          Float?
  answers        Answer[]
  evaluation     Evaluation?
}

model Answer {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  session    Session  @relation(fields: [sessionId], references: [id])
  sessionId  String
  question   String
  response   String
  score      Float?
}

model Evaluation {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  session        Session  @relation(fields: [sessionId], references: [id])
  sessionId      String   @unique
  reviewer       User     @relation(fields: [reviewerId], references: [id])
  reviewerId     String
  technical      Int      @default(0)
  communication  Int      @default(0)
  problemSolving Int      @default(0)
  confidence     Int      @default(0)
  overall        Int      @default(0)
  feedback       String?
}

model CodingChallenge {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  title            String
  slug             String    @unique
  difficulty       Difficulty
  category         String
  description      String
  totalSubmissions Int       @default(0)
  acceptedSubmissions Int    @default(0)
}
