generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum CandidateStage {
  APPLIED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  SHORTLISTED
  HIRED
  REJECTED
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  CODING
  VOICE
  MIXED
  APTITUDE
  LIVE
}

enum InterviewStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id                   String         @id @default(uuid())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  name                 String
  email                String         @unique
  password             String?
  googleId             String?        @unique
  image                String?
  role                 Role           @default(CANDIDATE)
  onboardingCompleted  Boolean        @default(false)
  organization         Organization?  @relation(fields: [organizationId], references: [id])
  organizationId       String?
  interviews           Interview[]       @relation("InterviewCreator")
  resumes              Resume[]
  sessions             Session[]
  evaluations          Evaluation[]
  assessments          Assessment[]      @relation("AssessmentCreator")
  invites              CandidateInvite[] @relation("InvitedCandidate")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  interviews  Interview[]
}

model Interview {
  id              String        @id @default(uuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  title           String
  description     String?
  type            InterviewType @default(TECHNICAL)
  status          InterviewStatus @default(DRAFT)
  targetRole      String
  difficulty      Difficulty     @default(MEDIUM)
  questionCount   Int             @default(5)
  durationMinutes Int             @default(30)
  totalScore      Float?         
  createdBy       User?          @relation("InterviewCreator", fields: [createdById], references: [id])
  createdById     String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  organizationId  String?
  sessions        Session[]
}

model Resume {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  fileUrl    String
  parsedText String?
  summary    String?
}

model Session {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  interview      Interview      @relation(fields: [interviewId], references: [id])
  interviewId    String
  user           User           @relation(fields: [userId], references: [id])
  userId         String
  status         InterviewStatus @default(SCHEDULED)
  startedAt      DateTime?
  endedAt        DateTime?
  score          Float?
  answers        Answer[]
  evaluation     Evaluation?
}

model Answer {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  session    Session  @relation(fields: [sessionId], references: [id])
  sessionId  String
  question   String
  response   String
  score      Float?
}

model Evaluation {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  session        Session  @relation(fields: [sessionId], references: [id])
  sessionId      String   @unique
  reviewer       User     @relation(fields: [reviewerId], references: [id])
  reviewerId     String
  technical      Int      @default(0)
  communication  Int      @default(0)
  problemSolving Int      @default(0)
  confidence     Int      @default(0)
  overall        Int      @default(0)
  feedback       String?
}

model CodingChallenge {
  id                  String     @id @default(uuid())
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  title               String
  slug                String     @unique
  difficulty          Difficulty
  category            String
  pattern             String     @default("")
  description         String
  leetcodeId          Int?       @unique
  totalSubmissions    Int        @default(0)
  acceptedSubmissions Int        @default(0)
}

model Assessment {
  id              String            @id @default(uuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  title           String
  type            InterviewType     @default(TECHNICAL)
  difficulty      Difficulty        @default(MEDIUM)
  targetRole      String
  questionCount   Int               @default(5)
  durationMinutes Int               @default(30)
  questions       Json              @default("[]")
  isActive        Boolean           @default(true)
  createdBy       User              @relation("AssessmentCreator", fields: [createdById], references: [id])
  createdById     String
  invites         CandidateInvite[]
}

model CandidateInvite {
  id            String             @id @default(uuid())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  assessment    Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId  String
  email         String
  candidate     User?              @relation("InvitedCandidate", fields: [candidateId], references: [id])
  candidateId   String?
  stage         CandidateStage     @default(APPLIED)
  token         String             @unique @default(uuid())
  completedAt   DateTime?
  score         Float?
  notes         String?
  session       AssessmentSession?

  @@unique([assessmentId, email])
}

model AssessmentSession {
  id           String          @id @default(uuid())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  invite       CandidateInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  inviteId     String          @unique
  startedAt    DateTime?
  endedAt      DateTime?
  score        Float?
  answers      Json            @default("[]")
  aiEvaluation Json?
}
